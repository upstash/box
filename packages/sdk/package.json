{
  "name": "@buggyhunter/box",
  "version": "0.1.3",
  "description": "Upstash Box SDK - TypeScript client for async and parallel AI coding agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "example": "tsx examples/basic.ts",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "upstash",
    "box",
    "ai-agent",
    "coding-agent",
    "claude",
    "async",
    "parallel",
    "sdk",
    "api"
  ],
  "author": "Upstash",
  "license": "MIT",
  "devDependencies": {
    "@buggyhunter/box": "latest",
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/upstash/box"
  },
  "homepage": "https://upstash.com/docs/box",
  "dependencies": {
    "zod": "^4.3.6"
  }
}
